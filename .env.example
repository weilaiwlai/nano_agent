﻿# nanoagent global environment variables
DEBUG=false
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nanoagent
POSTGRES_HOST=202.204.62.144
POSTGRES_PORT=5432

# Database connection for services
DB_URL=postgresql+asyncpg://postgres:postgres@202.204.62.144:5432/nanoagent
# Optional dedicated write connection for controlled write tools.
# In production, prefer a separate DB user with minimal write privileges.
DB_WRITE_URL=postgresql+asyncpg://postgres:postgres@202.204.62.144:5432/nanoagent

# External providers (keep empty when using frontend BYOK + session_id)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3.5-plus
EMBEDDING_MODEL=text-embedding-v3

# Optional security allowlist for model gateway prefixes, comma-separated.
# Environment policy:
# - development: allow empty ALLOWED_LLM_BASE_URLS (warning only)
# - production: require non-empty ALLOWED_LLM_BASE_URLS (fail-closed at startup)
ENVIRONMENT=development
# Example:
# ALLOWED_LLM_BASE_URLS=https://dashscope.aliyuncs.com/compatible-mode/v1,https://api.openai.com/v1
ALLOWED_LLM_BASE_URLS=https://dashscope.aliyuncs.com/compatible-mode/v1,https://api.openai.com/v1,https://api.deepseek.com/v1,https://api.groq.com/openai/v1

# API and CORS security (recommended for public deployment)
CORS_ALLOW_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
CORS_ALLOW_CREDENTIALS=true
REQUIRE_API_AUTH=true
# Multiple keys are supported (comma-separated), rotate regularly.
AGENT_API_KEYS=dev_token_123456
# Frontend token. In multi-tenant mode, use a JWT that contains `sub`.
AGENT_API_TOKEN=dev_token_123456
# Multi-tenant isolation: require JWT identity and use `sub` as real user ID.
AUTH_REQUIRE_USER_SUB=false
# Keep false in production; true only for migration/debug.
AUTH_ALLOW_API_KEY_FALLBACK=false
# OIDC/JWT verification config:
JWT_JWKS_URL=
JWT_ISSUER=
JWT_AUDIENCE=
# Local/dev fallback when no JWKS is available (HS256).
JWT_HS256_SECRET=abC123def456GHI789jkl012MNO345PQR678 #change_me_local_jwt_hs256_secret
JWT_ALGORITHMS=RS256,ES256,HS256
JWT_LEEWAY_SECONDS=30

# Service-to-service auth between agent_service and mcp_server
MCP_REQUIRE_AUTH=true
MCP_SERVICE_TOKEN=dev_token_123456
# MCP query guardrails
MCP_QUERY_ROW_LIMIT=200
MCP_QUERY_TIMEOUT_MS=3000
MCP_SQL_MAX_LENGTH=4000
# Report delivery tool: safe-by-default mock mode.
# - REPORT_PROVIDER=mock: only log and return simulated success (default)
# - REPORT_PROVIDER=smtp: actual SMTP delivery
REPORT_PROVIDER=mock
REPORT_ALLOWED_EMAIL_DOMAINS=
REPORT_MAX_CONTENT_CHARS=12000
REPORT_CONTENT_SOFT_LIMIT=8000
# mcp_server graceful-degradation params: summary body + optional attachment
REPORT_SOFT_BODY_CHARS=2000
REPORT_SUMMARY_PREVIEW_CHARS=500
REPORT_ATTACH_OVERFLOW=true
REPORT_ATTACHMENT_PREFIX=nanoagent_report
# Assistant target length for email draft generation (prompt-side control)
EMAIL_DRAFT_TARGET_CHARS=2000
REPORT_SUBJECT=nanoagent Auto Report
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=10

# Internal service discovery
MCP_BASE_URL=http://localhost:8000

# LLM session store (BYOK V2)
REDIS_URL=redis://:123456789qwer@202.204.62.144:6379/0
# LangGraph checkpointer backend for HITL persistence.
# postgres: recommended default in this stack
# redis: optional (requires Redis Stack / RediSearch module)
# memory: development only (not persistent across restart)
GRAPH_CHECKPOINTER_BACKEND=postgres
GRAPH_CHECKPOINTER_REDIS_URL=redis://:123456789qwer@202.204.62.144:6379/0
GRAPH_CHECKPOINTER_POSTGRES_URL=postgresql://postgres:postgres@202.204.62.144:5432/nanoagent
GRAPH_CHECKPOINTER_PREFIX=nanoagent:graph
GRAPH_CHECKPOINTER_ALLOW_MEMORY_FALLBACK=true
# Master key for encrypting BYOK API keys at rest in Redis.
# Use a long random string and rotate in a controlled manner.
LLM_SESSION_MASTER_KEY=Kj8pL2qR9zX5vB3mN6wE7cF1dG4hJ0kL9pQ2wE5rT8yU1 #change_me_llm_session_master_key
LLM_SESSION_TTL_SECONDS=3600
LLM_SESSION_MAX_TTL_SECONDS=86400
REQUIRE_LLM_SESSION=true
GRAPH_RECURSION_LIMIT=25
TAVILY_API_KEY=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